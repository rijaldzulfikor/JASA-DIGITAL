# Enforce consistent line endings across the repo to prevent LF/CRLF warnings
* text=auto eol=lf

# Keep common source/config files LF (recommended for cross-platform consistency)
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.config text eol=lf
*.env text eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

