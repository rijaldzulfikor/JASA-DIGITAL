root = true

# Default: enforce LF for text files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Binary files shouldn't be normalized as text
[*.ico]
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset

[*.png]
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset

[*.jpg]
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset

[*.jpeg]
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset

[*.gif]
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset

[*.webp]
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset

